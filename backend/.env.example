# 環境設定
ENVIRONMENT=development

# PostgreSQL接続情報
POSTGRES_USER=ui_recommender
POSTGRES_PASSWORD=ui_recommender
POSTGRES_DB=ui_recommender
POSTGRES_SERVER=db
POSTGRES_PORT=5432

# Kubernetes設定
K8S_NAMESPACE=default
K8S_IN_CLUSTER=false

# Artifact保存先
ARTIFACTS_DIR=/tmp/ui-recommender-artifacts

# Worker設定
WORKER_IMAGE=ui-recommender-worker:latest
WORKER_DEADLINE_SECONDS=900
MAX_PROPOSALS=3

# GitHub Token（PR作成用）
GITHUB_TOKEN=
